# AUD-MEM-1: fix upstream double-QMALLOC leak in SEP (kbarbary/sep v1.2.1).
# convert_to_catalog() in src/extract.c allocates cat->cflux and cat->flux,
# then allocates them AGAIN a few lines later (copy-paste duplicate) before
# either buffer is ever used — QMALLOC() is a bare malloc() with no free(),
# so the second call overwrites the pointer and leaks the first allocation.
# Confirmed present in upstream main as of 2026-07 (not AstroFind's bug;
# StarDetector.cpp correctly calls sep_catalog_free()). Leaks 44 bytes / 6
# allocations per successful detectStars() call (grows with sources x frames
# in long sessions / blink). Fix: drop the redundant second allocation pair.
--- a/src/extract.c
+++ b/src/extract.c
@@ -1099,8 +1099,6 @@
   QMALLOC(cat->ycpeak, int, nobj, status);
   QMALLOC(cat->xpeak, int, nobj, status);
   QMALLOC(cat->ypeak, int, nobj, status);
-  QMALLOC(cat->cflux, float, nobj, status);
-  QMALLOC(cat->flux, float, nobj, status);
   QMALLOC(cat->flag, short, nobj, status);

   /* fill output arrays */
